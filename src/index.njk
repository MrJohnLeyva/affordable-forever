<!-- ============ JOIN ============ -->
<section class="section" id="join" style="background:var(--navy-d);color:#fff">
  <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start">
    <div>
      <div class="eyebrow">Join</div>
      <h2 style="color:#fff;margin-top:14px">Is your building on the clock?</h2>
      <p style="color:#a9bad3;margin-top:16px;font-size:18px;line-height:1.75">
        There are hundreds of buildings in this state in exactly this position, and almost none
        of them know about each other. Each one thinks it has a landlord problem.
      </p>
      <p style="color:#a9bad3;margin-top:14px;font-size:18px;line-height:1.75">
        It doesn't. It has a <strong style="color:#fff">program</strong> problem — and there are
        hundreds of us.
      </p>
      <p style="color:#8fa3c0;margin-top:20px;font-size:15px">
        I'm building the list that should already exist. No organization, no funder, no budget.
        Just a tenant who ran out of time and started counting.
      </p>
    </div>

    <form name="join" method="POST" data-netlify="true" netlify-honeypot="bot-field"
          style="background:#ffffff0d;border:1px solid #ffffff26;border-radius:22px;padding:28px">
      <input type="hidden" name="form-name" value="join">
      <p hidden><label>Skip: <input name="bot-field"></label></p>

      <label style="display:block;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8fa3c0;margin-bottom:7px">Your name</label>
      <input name="name" type="text" required style="width:100%;padding:13px 14px;border-radius:12px;border:1px solid #ffffff2b;background:#ffffff0f;color:#fff;font-family:inherit;font-size:15px">

      <label style="display:block;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8fa3c0;margin:16px 0 7px">Email</label>
      <input name="email" type="email" required style="width:100%;padding:13px 14px;border-radius:12px;border:1px solid #ffffff2b;background:#ffffff0f;color:#fff;font-family:inherit;font-size:15px">

      <label style="display:block;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8fa3c0;margin:16px 0 7px">Your building's address <span style="text-transform:none;letter-spacing:0;font-weight:500">(if you're in one)</span></label>
      <input name="address" type="text" style="width:100%;padding:13px 14px;border-radius:12px;border:1px solid #ffffff2b;background:#ffffff0f;color:#fff;font-family:inherit;font-size:15px">

      <label style="display:block;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8fa3c0;margin:16px 0 7px">What's happening where you live?</label>
      <textarea name="story" rows="4" style="width:100%;padding:13px 14px;border-radius:12px;border:1px solid #ffffff2b;background:#ffffff0f;color:#fff;font-family:inherit;font-size:15px" placeholder="Expiration date, landlord, tenants association…"></textarea>

      <button type="submit" class="btn btn-gold" style="width:100%;margin-top:20px;padding:15px">Add my name</button>
      <p style="margin-top:12px;font-size:13px;color:#8fa3c0;line-height:1.6">
        I'll email you when something needs doing. Nothing else, and never your details to anyone.
      </p>
    </form>
  </div>
</section>

<style>
  @media(max-width:900px){
    #join .container{grid-template-columns:1fr !important}
  }
</style>
