      <input name="name" type="text" required style="width:100%;padding:13px 14px;border-radius:12px;border:1px solid #ffffff2b;background:#ffffff0f;color:#fff;font-family:inherit;font-size:16px">

      <label style="display:block;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8fa3c0;margin:16px 0 7px">Email</label>
      <input name="email" type="email" required style="width:100%;padding:13px 14px;border-radius:12px;border:1px solid #ffffff2b;background:#ffffff0f;color:#fff;font-family:inherit;font-size:16px">

      <label style="display:block;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8fa3c0;margin:16px 0 7px">Your building's address <span style="text-transform:none;letter-spacing:0;font-weight:500">(if you're in one)</span></label>
      <input name="address" type="text" style="width:100%;padding:13px 14px;border-radius:12px;border:1px solid #ffffff2b;background:#ffffff0f;color:#fff;font-family:inherit;font-size:16px">

      <label style="display:block;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8fa3c0;margin:16px 0 7px">What's happening where you live?</label>
      <textarea name="story" rows="4" style="width:100%;padding:13px 14px;border-radius:12px;border:1px solid #ffffff2b;background:#ffffff0f;color:#fff;font-family:inherit;font-size:16px" placeholder="Expiration date, landlord, tenants association…"></textarea>

      <button type="submit" class="btn btn-gold" style="width:100%;margin-top:20px;padding:15px">Add my name</button>
      <p style="margin-top:12px;font-size:13px;color:#8fa3c0;line-height:1.6">
        I'll email you when something needs doing. Nothing else, and never your details to anyone.
      </p>
    </form>
  </div>
</section>

