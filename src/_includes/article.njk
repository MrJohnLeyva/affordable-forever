---
layout: base.njk
---
<header class="hero">
  <div class="container narrow">
    <div class="eyebrow">{{ tag or "Article" }}</div>
    <h1 style="font-size:40px">{{ title }}</h1>
    {% if description %}<p class="deck">{{ description }}</p>{% endif %}
    <p style="margin-top:20px;font-size:14px;color:#8fa3c0;font-weight:600;letter-spacing:.06em;text-transform:uppercase">
      {{ date | readableDate }}{% if author %} · {{ author }}{% endif %}
    </p>
  </div>
</header>

<main class="section">
  <div class="container narrow">
    <article class="prose">
      {{ content | safe }}
    </article>

    <div style="margin-top:56px;padding-top:26px;border-top:2px solid var(--line)">
      <a href="/articles/" style="font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--navy);text-decoration:none">← All articles</a>
    </div>
  </div>
</main>
