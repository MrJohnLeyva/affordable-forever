  .answer{margin-top:30px;display:none}
  .answer.show{display:block;animation:rise .5s ease}
  @keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}

  .verdict{
    background:var(--navy);color:#fff;border-radius:24px;padding:44px 36px;text-align:center;
    border-bottom:6px solid var(--gold);
  }
  .verdict .lead{font-size:16px;color:#b9c9e0;letter-spacing:.04em}
  .big{font-size:96px;font-weight:800;line-height:1;color:var(--gold);margin:10px 0}
  .verdict .tail{font-size:24px;font-weight:600;line-height:1.35;max-width:22ch;margin:0 auto}
  .verdict.gone{border-bottom-color:var(--red)}
